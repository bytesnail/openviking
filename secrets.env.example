# 复制本文件为 secrets.env 并填入真实值。
# secrets.env 已在 .gitignore 中忽略,不会被提交。
#
# 工作方式:
#   - docker-compose.yml 通过 env_file 引用 secrets.env,启动时注入容器环境变量;
#   - ov.conf 内对应字段使用 ${VAR} 占位,由 openviking(config_loader.py 的 os.path.expandvars)展开。
OPENVIKING_ROOT_API_KEY=sk-openviking-REPLACE_WITH_REAL_KEY
OPENVIKING_VLM_API_KEY=sk-kimi-REPLACE_WITH_REAL_KEY
